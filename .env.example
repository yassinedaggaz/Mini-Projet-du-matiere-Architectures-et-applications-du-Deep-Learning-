# Environment variables for the Deep Learning API
# Copy to .env and modify as needed

# Model Configuration
MODEL_PATH=models/best_model.pth
CLASS_MAP_PATH=models/class_to_idx.json
MODEL_VERSION=1.0.0

# Logging
LOG_LEVEL=INFO

# Python
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Development (set to true for development only)
DEBUG=false
